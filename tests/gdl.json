    },
    "SamePoint(A,B)": {
      "geometric_constraints": "Point(A)&Point(B)",
      "algebraic_forms": "Eq(Norm(A.x,A.y,B.x,B.y))"
    },
    "SameLine(l,m)": {
      "geometric_constraints": "Line(l)&Line(m)",
      "algebraic_forms": "Eq(Norm(l.k,l.b,m.k,m.b))"
    },
    "SameCircle(O,P)": {
      "geometric_constraints": "Circle(O)&Circle(P)",
      "algebraic_forms": "Eq(Norm(O.u,O.v,P.u,P.v))&Eq(Sub(O.r,P.r))&G(O.r)&G(P.r)"
    },
    "PointOnLine(A,l)": {
      "geometric_constraints": "Point(A)&Line(l)",
      "algebraic_forms": "Eq(Sub(A.y,Add(Mul(l.k,A.x),l.b)))"
    },
    "PointOnCircle(A,O)": {
      "geometric_constraints": "Point(A)&Circle(O)",
      "algebraic_forms": "Eq(Pp(A.x,A.y,O.u,O.v,O.r))&G(O.r)"
    },
    "PointLeftSegment(P,A,B)": {
      "geometric_constraints": "Point(P)&Point(A)&Point(B)",
      "algebraic_forms": "~SamePoint(A,B)&G(Sub(Mul(Sub(B.x,A.x),Sub(P.y,A.y)),Mul(Sub(B.y,A.y),Sub(P.x,A.x))))"
    },
    "ParallelBetweenLine(l,m)": {
      "geometric_constraints": "Line(l)&Line(m)",
      "algebraic_forms": "Eq(Sub(l.k,m.k))&Ueq(Sub(l.b,m.b))"
    },
    "EqualDistance(A,B,C,D)": {
      "geometric_constraints": "Point(A)&Point(B)&Point(C)&Point(D)",
      "algebraic_forms": "Eq(Sub(Norm(A.x,A.y,B.x,B.y),Norm(C.x,C.y,D.x,D.y)))&~(SamePoint(A,C)&SamePoint(B,D))"
    },
    "EqualAngle(l,m,x,y)": {
      "geometric_constraints": "Line(l)&Line(m)&Line(x)&Line(y)",
      "algebraic_forms": "Eq(Sub(Ma(l.k,m.k),Ma(x.k,y.k)))&Ueq(Norm(l.k,l.b,m.k,m.b))&Ueq(Norm(l.k,l.b,x.k,x.b))"
    },
    "AngleBisector(O,l,a,b)": {
      "geometric_constraints": "Point(O)&Line(l)&Line(a)&Line(b)",
      "algebraic_forms": "PointOnLine(O,l)&PointOnLine(O,a)&PointOnLine(O,b)&~SameLine(a,b)&EqualAngle(a,l,l,b)&Eq(Sub(Add(Ma(a.k,l.k),Ma(l.k,b.k)),Ma(a.k,b.k)))"
    },
    "MidpointOfArc(M,O,A,B)": {
      "geometric_constraints": "Point(M)&Circle(O)&Point(A)&Point(B)",
      "algebraic_forms": "PointOnCircle(M,O)&PointOnCircle(A,O)&PointOnCircle(B,O)&EqualDistance(A,M,A,B)&~SamePoint(A,B)&PointLeftSegment(M,B,A)"
    }
  },
