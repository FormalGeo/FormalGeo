      "premises": "PointOnLine(O,l)&PointOnLine(O,a)&PointOnLine(O,b)&Eq(Sub(al.ma,lb.ma))",
      "conclusion": "AngleBisector(O,l,a,b)"
    },
    "angle_bisector_property_distance_equal(O,A,l,a,b)": {
